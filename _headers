# Security headers for all responses
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin
  Content-Security-Policy: frame-ancestors 'self'
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), interest-cohort=(), usb=(), accelerometer=(), gyroscope=(), magnetometer=(), autoplay=(), picture-in-picture=()

# HTML always revalidates so deploys go live immediately
/
  Cache-Control: public, max-age=0, must-revalidate
/*/
  Cache-Control: public, max-age=0, must-revalidate

/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Static assets: 1-day cache (filenames are not content-hashed, so keep it modest)
/*.css
  Cache-Control: public, max-age=86400
/*.js
  Cache-Control: public, max-age=86400
/*.svg
  Cache-Control: public, max-age=86400
/*.png
  Cache-Control: public, max-age=86400
/*.jpg
  Cache-Control: public, max-age=86400
/*.jpeg
  Cache-Control: public, max-age=86400
/*.webp
  Cache-Control: public, max-age=86400
/*.woff2
  Cache-Control: public, max-age=2592000
/*.ttf
  Cache-Control: public, max-age=2592000
